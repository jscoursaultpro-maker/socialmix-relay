# ─── relay-server environment variables ─────────────────────────────
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Core ──
PORT=3000
MONGODB_URI=              # MongoDB Atlas connection string

# ── Auth secrets (generate with: openssl rand -hex 64) ──
JWT_SECRET=               # 128-char hex — used for session tokens
REFRESH_SECRET=           # 128-char hex — used for refresh tokens
ADMIN_PASSWORD=           # Strong admin dashboard password (required)

# ── Supabase (auth) ──
SUPABASE_URL=             # https://xxx.supabase.co
SUPABASE_ANON_KEY=        # Supabase anon/public key
SUPABASE_SERVICE_ROLE_KEY= # Supabase service role key (server-only, NEVER expose to client)

# ── Cloudinary (photo uploads) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=

# ── SendGrid (transactional emails) ──
SENDGRID_API_KEY=

# ── Sentry (error tracking) ──
SENTRY_DSN=

# ── Render (deploy API) ──
RENDER_API_TOKEN=         # Render API token for automated deploys

# ── Branding ──
BRAND_NAME=AhOuai
BRAND_EMAIL=
BRAND_DOMAIN=
